# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
AUTO_BOOK_WIX_WEBHOOKS=false
# Default true manifests shipments through Delhivery and creates an AWB.
# Set false only when you want the app to queue orders without calling Delhivery.
CREATE_AWB_ON_BOOK=true

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Set true in production to require Supabase Auth sessions for CRM pages.
AUTH_REQUIRED=true

# Chatwoot
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=

# Amazon SP-API placeholders
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=

# FedEx / Shree Maruti placeholders
FEDEX_BASE_URL=https://apis.fedex.com
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_TRACKING_ENABLED=false
FEDEX_TRACKING_BATCH_SIZE=10
FEDEX_TRACKING_URL_TEMPLATE=https://www.fedex.com/fedextrack/?trknbr={waybill}
FEDEX_WEBHOOK_SECRET=
SHREE_MARUTI_API_KEY=
SHREE_MARUTI_CUSTOMER_CODE=

# Wix
# Required if you want the app to fetch full order details from Wix after receiving a webhook.
WIX_AUTH_TOKEN=
# Required when WIX_AUTH_TOKEN is a Wix API key for site-level APIs such as eCommerce orders.
# You can find the site ID in the Wix dashboard URL after /dashboard/.
WIX_SITE_ID=
# Only use this for account-level Wix APIs. Leave blank for eCommerce orders.
WIX_ACCOUNT_ID=
# Optional: verify incoming JWT webhooks. Use the public key for RS256 webhooks or shared secret for HS256.
WIX_WEBHOOK_PUBLIC_KEY=
WIX_WEBHOOK_SECRET=
WIX_REQUEST_TIMEOUT_SECONDS=30
# Periodically pulls recently updated Wix orders into Supabase.
WIX_ORDER_SYNC_ENABLED=false
WIX_ORDER_SYNC_INTERVAL_MINUTES=5
WIX_ORDER_SYNC_PAGE_SIZE=25
WIX_ORDER_SYNC_MAX_PAGES=1
NEXT_PUBLIC_WIX_AUTO_SYNC_ON_OPEN=true
NEXT_PUBLIC_WIX_AUTO_SYNC_MIN_INTERVAL_SECONDS=120
WIX_AUTO_SYNC_MIN_INTERVAL_SECONDS=120
WIX_AUTO_SYNC_PAGE_SIZE=25
WIX_AUTO_SYNC_MAX_PAGES=1
WIX_AUTO_SYNC_FULFILLMENTS=true

# Delhivery
DELHIVERY_ENV=staging
DELHIVERY_API_TOKEN=
# Optional. The app does not send this by default because most Delhivery tokens map the client automatically.
DELHIVERY_CLIENT_NAME=
DELHIVERY_PICKUP_LOCATION=
DELHIVERY_PICKUP_PINCODE=
DELHIVERY_RETURN_NAME=
DELHIVERY_RETURN_ADDRESS=
DELHIVERY_RETURN_CITY=
DELHIVERY_RETURN_STATE=
DELHIVERY_RETURN_PINCODE=
DELHIVERY_RETURN_PHONE=
# Optional. Defaults to Delhivery packing slip endpoint for DELHIVERY_ENV.
# Use {waybill} if your account has a custom label URL format.
DELHIVERY_LABEL_URL=

# Delhivery Automatic Tracking
# Set to true to poll Delhivery for shipment status updates automatically.
DELHIVERY_TRACKING_ENABLED=false
# How often to poll (in minutes). Default: 30.
DELHIVERY_TRACKING_INTERVAL_MINUTES=30
# Number of waybills fetched per API call (max 50). Default: 25.
DELHIVERY_TRACKING_BATCH_SIZE=25

# Shiprocket Tracking
# Set shipment courier_code to "shiprocket" for Shiprocket AWBs.
SHIPROCKET_API_TOKEN=
# Optional fallback if you prefer the app to request a bearer token from /auth/login.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external
SHIPROCKET_TRACKING_ENABLED=false
SHIPROCKET_TRACKING_BATCH_SIZE=10
SHIPROCKET_TRACKING_URL_TEMPLATE=https://www.shiprocket.in/shipment-tracking/{waybill}

# Shipment defaults
DEFAULT_SELLER_GST_TIN=
DEFAULT_HSN_CODE=
DEFAULT_WEIGHT_GRAMS=400
DEFAULT_LENGTH_CM=23
DEFAULT_WIDTH_CM=14
DEFAULT_HEIGHT_CM=6
DEFAULT_PAYMENT_MODE=Prepaid
# Express/Air = Express or E. Surface = Surface or S.
DEFAULT_SHIPPING_MODE=Express
# Used for international pending payloads: Commercial (CSB5), Sample (CSB4), Gifts, Document, etc.
DEFAULT_INTERNATIONAL_SHIPMENT_TYPE=Sample
# Optional local rate card used until Delhivery provides an account-enabled international rate API.
# Example:
# INTERNATIONAL_RATE_CARD_JSON={"US":{"Deferred Express":[{"uptoGrams":500,"amount":1200,"tatDays":"5-8"}],"DLV Saver":[{"uptoGrams":500,"amount":900,"tatDays":"8-12"}]},"DEFAULT":{"Deferred Express":[{"uptoGrams":500,"amount":1500}],"DLV Saver":[{"uptoGrams":500,"amount":1100}]}}
INTERNATIONAL_RATE_CARD_JSON=
